// Quarter helper
function getQtr(dateStr) {
    var m = parseInt((dateStr || '').substring(5, 7), 10);
    if (m <= 3) return 'Q1';
    if (m <= 6) return 'Q2';
    if (m <= 9) return 'Q3';
    return 'Q4';
}

var currentQtr    = 'all';
var currentFilter = 'all';
var typeChartInst = null;
var donutInst     = null;

// ── QTR toggle ────────────────────────────────────────────────────────────────
function setQtr(qtr, el) {
    currentQtr = qtr;
    document.querySelectorAll('.qtr-btn').forEach(function(b) { b.classList.remove('active'); });
    el.classList.add('active');
    currentFilter = 'all';
    document.querySelectorAll('.eo-filter-btn').forEach(function(b) { b.classList.remove('active'); });
    document.querySelectorAll('.eo-filter-btn')[0].classList.add('active');
    var s = document.getElementById('eoSearch'); if (s) s.value = '';
    refreshAll();
}

function filteredData() {
    if (currentQtr === 'all') return DUMMY;
    return DUMMY.filter(function(r) { return getQtr(r.created_date) === currentQtr; });
}

// ── Main refresh ──────────────────────────────────────────────────────────────
function refreshAll() {
    var data      = filteredData();
    var total     = data.length;
    var hired     = data.filter(function(r) { return r.outcome === 'Hired'; }).length;
    var completed = total - hired;
    var rate      = total > 0 ? Math.round((hired / total) * 100) : 0;

    // Cards
    document.getElementById('eoRingPct').textContent    = rate + '%';
    document.getElementById('eoRingSub').innerHTML      = hired + ' of ' + total + ' escalations<br>resulted in a hire';
    document.getElementById('eoCardTotal').textContent  = total;
    document.getElementById('eoCardTotalSub').textContent =
        'All types · ' + (currentQtr === 'all' ? 'All quarters' : currentQtr);
    document.getElementById('eoCardHired').textContent     = hired;
    document.getElementById('eoCardCompleted').textContent = completed;

    // Ring animation
    var circumference = 2 * Math.PI * 62;
    var offset = circumference - (rate / 100) * circumference;
    var ring = document.getElementById('eoRing');
    ring.style.transition = 'none';
    ring.style.strokeDashoffset = circumference;
    setTimeout(function() {
        ring.style.transition = 'stroke-dashoffset 1.4s cubic-bezier(0.4,0,0.2,1)';
        ring.style.strokeDashoffset = offset;
    }, 30);

    // Avg days
    var hDays = data.filter(function(r) { return r.outcome === 'Hired'; })
                    .reduce(function(s,r) { return s + r.days_open; }, 0);
    var cDays = data.filter(function(r) { return r.outcome === 'Completed'; })
                    .reduce(function(s,r) { return s + r.days_open; }, 0);
    document.getElementById('eoAvgHired').textContent     = hired     > 0 ? (hDays / hired).toFixed(1)     : '—';
    document.getElementById('eoAvgCompleted').textContent = completed > 0 ? (cDays / completed).toFixed(1) : '—';

    // Best type
    var typeBuckets = {};
    data.forEach(function(r) {
        var t = r.escalation_type || 'Unknown';
        if (!typeBuckets[t]) typeBuckets[t] = { hired: 0, completed: 0 };
        if (r.outcome === 'Hired') typeBuckets[t].hired++;
        else typeBuckets[t].completed++;
    });
    var bestType = '—', bestRate = -1;
    Object.keys(typeBuckets).forEach(function(t) {
        var b = typeBuckets[t], tot = b.hired + b.completed;
        var r = tot > 0 ? b.hired / tot : 0;
        if (r > bestRate) { bestRate = r; bestType = t; }
    });
    document.getElementById('eoBestType').textContent = total > 0 ? bestType : '—';
    document.getElementById('eoBestRate').textContent = total > 0
        ? 'Best-converting Type · ' + Math.round(bestRate * 100) + '%'
        : 'No data for this quarter';

    // Charts
    updateTypeChart(typeBuckets);
    updateDonut(hired, completed);

    // Table
    renderTable(currentFilter, data);
}

// ── Stacked bar chart ─────────────────────────────────────────────────────────
function updateTypeChart(typeBuckets) {
    var types     = Object.keys(typeBuckets).sort(function(a, b) {
        return (typeBuckets[b].hired + typeBuckets[b].completed) -
               (typeBuckets[a].hired + typeBuckets[a].completed);
    });
    var hiredData     = types.map(function(t) { return typeBuckets[t].hired; });
    var completedData = types.map(function(t) { return typeBuckets[t].completed; });

    if (typeChartInst) {
        typeChartInst.data.labels              = types;
        typeChartInst.data.datasets[0].data    = hiredData;
        typeChartInst.data.datasets[1].data    = completedData;
        typeChartInst.options.scales.y.max     = Math.max(14, Math.max.apply(null, types.map(function(t) {
            return typeBuckets[t].hired + typeBuckets[t].completed;
        })) + 2);
        typeChartInst.update();
        return;
    }

    typeChartInst = new Chart(document.getElementById('eoTypeChart'), {
        type: 'bar',
        data: {
            labels: types,
            datasets: [
                {
                    label: 'Hired',
                    data: hiredData,
                    backgroundColor: '#00d4aa',
                    borderRadius: 4, borderSkipped: false
                },
                {
                    label: 'Completed',
                    data: completedData,
                    backgroundColor: 'rgba(255,107,107,0.85)',
                    borderRadius: 4, borderSkipped: false
                }
            ]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            scales: {
                x: {
                    stacked: true,
                    ticks: { color: '#5a6a85', font: { family: 'DM Sans', size: 13 } },
                    grid:  { color: 'rgba(255,255,255,0.04)' }
                },
                y: {
                    stacked: true,
                    ticks: { color: '#5a6a85', precision: 0, font: { family: 'DM Sans' } },
                    grid:  { color: 'rgba(255,255,255,0.04)' },
                    max: 18
                }
            },
            plugins: {
                legend: {
                    labels: {
                        color: '#a3b1c9', font: { family: 'DM Sans', size: 13 },
                        usePointStyle: true, pointStyle: 'circle', padding: 20
                    }
                },
                tooltip: {
                    callbacks: {
                        footer: function(items) {
                            var tot = items.reduce(function(s,i) { return s + i.parsed.y; }, 0);
                            var h   = items.find(function(i) { return i.dataset.label === 'Hired'; });
                            var r   = h && tot > 0 ? Math.round((h.parsed.y / tot) * 100) : 0;
                            return 'Total: ' + tot + ' · ' + r + '% hired';
                        }
                    }
                },
                datalabels: {
                    color: '#fff',
                    font: { family: 'DM Sans', size: 12, weight: '700' },
                    formatter: function(v) { return v > 0 ? v : ''; }
                }
            }
        }
    });
}

// ── Donut ─────────────────────────────────────────────────────────────────────
var eoCenterPlugin = {
    id: 'eoCenter',
    afterDraw: function(chart) {
        var d = chart.data.datasets[0].data, tot = d[0] + d[1];
        if (!tot) return;
        var pct = Math.round((d[0] / tot) * 100);
        var ctx = chart.ctx;
        var cx  = (chart.chartArea.left + chart.chartArea.right)  / 2;
        var cy  = (chart.chartArea.top  + chart.chartArea.bottom) / 2;
        ctx.save();
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.font = "bold 30px 'Space Mono', monospace";
        ctx.fillStyle = '#00d4aa';
        ctx.fillText(pct + '%', cx, cy - 12);
        ctx.font = '14px DM Sans'; ctx.fillStyle = '#a3b1c9';
        ctx.fillText('hired', cx, cy + 16);
        ctx.restore();
    }
};

function updateDonut(hired, completed) {
    if (donutInst) {
        donutInst.data.datasets[0].data = [hired, completed];
        donutInst.update();
        return;
    }
    donutInst = new Chart(document.getElementById('eoDonutChart'), {
        type: 'doughnut',
        data: {
            labels: ['Hired', 'Completed'],
            datasets: [{ data: [hired, completed], backgroundColor: ['#00d4aa', 'rgba(255,107,107,0.85)'], borderWidth: 0 }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: { color: '#a3b1c9', font: { family: 'DM Sans', size: 13 }, padding: 24, usePointStyle: true, pointStyle: 'circle' }
                },
                datalabels: { display: false }
            },
            cutout: '68%'
        },
        plugins: [eoCenterPlugin]
    });
}

function onEoSearch() { renderTable(currentFilter); }

// ── Table ─────────────────────────────────────────────────────────────────────
function renderTable(filter, data) {
    var rows = data || filteredData();
    if (filter === 'hired')     rows = rows.filter(function(r) { return r.outcome === 'Hired'; });
    if (filter === 'completed') rows = rows.filter(function(r) { return r.outcome === 'Completed'; });

    var q = (document.getElementById('eoSearch').value || '').toLowerCase().trim();
    if (q) {
        rows = rows.filter(function(r) {
            return (r.opportunity     || '').toLowerCase().indexOf(q) >= 0 ||
                   (r.escalation_type || '').toLowerCase().indexOf(q) >= 0 ||
                   (r.type_reason     || '').toLowerCase().indexOf(q) >= 0 ||
                   (r.outcome         || '').toLowerCase().indexOf(q) >= 0;
        });
    }

    rows = rows.slice().sort(function(a, b) {
        if (a.outcome !== b.outcome) return a.outcome === 'Completed' ? -1 : 1;
        return b.days_open - a.days_open;
    });

    var total = filteredData().length;
    var countEl = document.getElementById('eoSearchCount');
    if (countEl) {
        countEl.textContent = q
            ? 'Found ' + rows.length + ' of ' + total + ' records'
            : 'Showing ' + rows.length + ' records';
    }

    var html = rows.map(function(r) {
        var isHired = r.outcome === 'Hired';
        var daysCol = r.days_open > 14 ? 'var(--demand-primary)' : r.days_open > 7 ? 'var(--accent-orange)' : 'var(--text-secondary)';
        return '<tr>' +
            '<td class="date-cell">' + r.created_date + '</td>' +
            '<td style="color:var(--text-primary);font-weight:600">' + r.opportunity + '</td>' +
            '<td style="color:var(--accent-purple);font-weight:600">' + r.escalation_type + '</td>' +
            '<td>' + r.type_reason + '</td>' +
            '<td style="font-family:\'Space Mono\',monospace;font-weight:700;color:' + daysCol + '">' + r.days_open + 'd</td>' +
            '<td><span class="outcome-badge ' + (isHired ? 'hired' : 'unresolved') + '">' + r.outcome + '</span></td>' +
            '<td><a href="#" class="candidate-linkedin" onclick="return false">View</a></td>' +
            '</tr>';
    }).join('');

    document.getElementById('eoTableBody').innerHTML = html ||
        '<tr><td colspan="7" style="text-align:center;padding:48px;color:var(--text-muted)">No records match.</td></tr>';
}

function setFilter(filter, el) {
    currentFilter = filter;
    document.querySelectorAll('.eo-filter-btn').forEach(function(b) { b.classList.remove('active'); });
    el.classList.add('active');
    renderTable(filter);
}

// ── Boot ──────────────────────────────────────────────────────────────────────
window.addEventListener('load', function() { refreshAll(); });
</script>
