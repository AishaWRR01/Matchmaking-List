<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Escalation Outcomes — Preview</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
    <style>
        :root {
            --bg-primary: #0a0e17;
            --bg-secondary: #121a2b;
            --bg-card: #1a2438;
            --bg-elevated: #232f47;
            --supply-primary: #00d4aa;
            --supply-secondary: #00f5c4;
            --supply-muted: rgba(0, 212, 170, 0.15);
            --demand-primary: #ff6b6b;
            --demand-secondary: #ff8e8e;
            --demand-muted: rgba(255, 107, 107, 0.15);
            --text-primary: #ffffff;
            --text-secondary: #a3b1c9;
            --text-muted: #5a6a85;
            --border: rgba(255, 255, 255, 0.06);
            --accent-purple: #9d7bff;
            --accent-blue: #4da6ff;
            --accent-orange: #ffaa4d;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
        }

        /* ── Shared layout ───────────────────────────────────────── */
        .container { max-width: 1600px; margin: 0 auto; padding: 32px 40px; }

        /* Header bar (mock) */
        .mock-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 40px;
            padding-bottom: 0;
        }
        .mock-header h1 { font-size: 28px; font-weight: 700; letter-spacing: -0.5px; margin-bottom: 4px; }
        .mock-header p  { font-size: 14px; color: var(--text-muted); }

        /* Tab nav (mock) */
        .tab-navigation {
            display: flex;
            margin-bottom: 32px;
            border-bottom: 1px solid var(--border);
        }
        .tab-button {
            background: none; border: none;
            color: var(--text-muted);
            font-size: 15px; font-weight: 600;
            padding: 14px 24px; cursor: pointer;
            font-family: 'DM Sans', sans-serif;
            border-bottom: 2px solid transparent;
            margin-bottom: -1px; transition: all 0.2s;
        }
        .tab-button.active { color: var(--supply-primary); border-bottom-color: var(--supply-primary); }

        /* ── Cards ───────────────────────────────────────────────── */
        .key-metrics {
            display: grid;
            grid-template-columns: auto 1fr 1fr 1fr;
            gap: 20px;
            margin-bottom: 28px;
            align-items: stretch;
        }
        .metric-card {
            background: var(--bg-card);
            border-radius: 16px;
            padding: 24px;
            border: 1px solid var(--border);
            position: relative;
            overflow: hidden;
        }
        .metric-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
        }
        .metric-card.supply::before  { background: linear-gradient(90deg, var(--supply-primary), var(--supply-secondary)); }
        .metric-card.demand::before  { background: linear-gradient(90deg, var(--demand-primary), var(--demand-secondary)); }
        .metric-card.neutral::before { background: linear-gradient(90deg, var(--accent-purple), var(--accent-blue)); }

        .metric-label {
            font-size: 12px; font-weight: 600;
            text-transform: uppercase; letter-spacing: 0.8px;
            color: var(--text-muted); margin-bottom: 12px;
        }
        .metric-value {
            font-family: 'Space Mono', monospace;
            font-size: 36px; font-weight: 700;
            margin-bottom: 8px;
        }
        .metric-card.supply  .metric-value { color: var(--supply-primary); }
        .metric-card.demand  .metric-value { color: var(--demand-primary); }
        .metric-card.neutral .metric-value { color: var(--text-primary); }
        .metric-sub { font-size: 12px; color: var(--text-muted); margin-top: 8px; font-weight: 500; }

        /* ── Charts grid ─────────────────────────────────────────── */
        .charts-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 24px;
            margin-bottom: 28px;
        }
        .chart-card {
            background: var(--bg-card);
            border-radius: 16px;
            padding: 24px;
            border: 1px solid var(--border);
        }
        .chart-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; }
        .chart-title  { font-size: 16px; font-weight: 600; color: var(--text-primary); margin-bottom: 4px; }
        .chart-subtitle { font-size: 13px; color: var(--text-muted); }
        .chart-container { position: relative; height: 280px; }

        /* ── Time cards ──────────────────────────────────────────── */
        .time-analysis {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 28px;
        }
        .time-card {
            background: var(--bg-card);
            border-radius: 16px;
            padding: 24px;
            border: 1px solid var(--border);
            text-align: center;
        }
        .time-value { font-size: 36px; font-weight: 700; font-family: 'Space Mono', monospace; }
        .time-unit  { font-size: 12px; color: var(--text-muted); text-transform: uppercase; margin: 4px 0; }
        .time-label { font-size: 13px; color: var(--text-secondary); }

        /* ── Escalation section (table) ──────────────────────────── */
        .escalations-section {
            background: var(--bg-card);
            border-radius: 16px;
            padding: 24px;
            border: 1px solid var(--border);
            margin-bottom: 28px;
        }
        .escalation-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        .candidate-table { width: 100%; border-collapse: collapse; }
        .candidate-table thead { background: var(--bg-secondary); }
        .candidate-table th {
            text-align: left; padding: 14px 20px;
            font-size: 11px; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.5px;
            color: var(--text-muted);
            border-bottom: 2px solid var(--border);
        }
        .candidate-table td {
            padding: 14px 20px; font-size: 14px;
            color: var(--text-secondary);
            border-bottom: 1px solid var(--border);
        }
        .candidate-table tbody tr:hover { background: var(--bg-secondary); }
        .candidate-linkedin {
            color: var(--supply-primary); text-decoration: none;
            font-weight: 600; font-size: 13px;
        }
        .date-cell {
            font-family: 'Space Mono', monospace;
            font-size: 12px; color: var(--text-muted);
        }

        /* ── QTR toggle ──────────────────────────────────────────── */
        .qtr-btn {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 8px 20px;
            font-size: 13px; font-weight: 700;
            cursor: pointer;
            font-family: 'DM Sans', sans-serif;
            color: var(--text-muted);
            letter-spacing: 0.5px;
            transition: all 0.18s;
        }
        .qtr-btn:hover { color: var(--text-primary); border-color: rgba(255,255,255,0.18); }
        .qtr-btn.active {
            background: var(--supply-muted);
            border-color: var(--supply-primary);
            color: var(--supply-primary);
        }

        /* ── Filter buttons ──────────────────────────────────────── */
        .filter-row { display: flex; gap: 8px; }
        .eo-filter-btn {
            background: var(--bg-elevated);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 6px 14px;
            font-size: 12px; font-weight: 600;
            cursor: pointer;
            font-family: 'DM Sans', sans-serif;
            color: var(--text-secondary);
            transition: all 0.2s;
        }
        .eo-filter-btn.active { background: var(--bg-secondary); color: var(--text-primary); border-color: rgba(255,255,255,0.15); }
        .eo-filter-btn.hired-btn  { color: var(--supply-primary); }
        .eo-filter-btn.open-btn   { color: var(--demand-primary); }

        /* ── Badge ───────────────────────────────────────────────── */
        .outcome-badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 11px; font-weight: 700;
            display: inline-block;
        }
        .outcome-badge.hired      { background: rgba(0,212,170,0.15); color: var(--supply-primary); }
        .outcome-badge.unresolved { background: rgba(255,107,107,0.15); color: var(--demand-primary); }
    </style>
</head>
